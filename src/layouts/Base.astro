---
import '../styles/global.css';
import { ViewTransitions } from 'astro:transitions';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';

interface Props {
  title?: string;
  description?: string;
  ogPath?: string;
}

const {
  title = 'Chinese Fables, English Wisdom — Timeless Parables Across Civilizations',
  description = '20 Chinese fables paired with their English idiomatic counterparts. Stories, morals, and cross-cultural reflections.',
  ogPath = '',
} = Astro.props;

const canonicalURL = new URL(ogPath, Astro.site).toString();
const GA4_ID = 'G-XXXXXXXXXX'; // ← Replace with your real GA4 Measurement ID
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#07080b" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Fonts: Inter, JetBrains Mono, Ma Shan Zheng (中文标题), Noto Serif SC (中文正文) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&family=Ma+Shan+Zheng&family=Noto+Serif+SC:wght@400;500;600;700&display=swap"
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>

    <ViewTransitions />

    {/* Google Analytics 4 — loaded only after user accepts cookies.
        The check is inline because gtag's consent mode treats denies as
        "analytics_storage: denied" and we never even load the script until
        localStorage says 'accepted'. */}
    <script is:inline define:vars={{ GA4_ID }}>
      (function () {
        try {
          if (localStorage.getItem('cookie-consent') !== 'accepted') return;
          // Inject the GA4 loader
          var s = document.createElement('script');
          s.async = true;
          s.src = 'https://www.googletagmanager.com/gtag/js?id=' + GA4_ID;
          document.head.appendChild(s);
          // gtag stub
          window.dataLayer = window.dataLayer || [];
          function gtag(){ dataLayer.push(arguments); }
          window.gtag = gtag;
          gtag('js', new Date());
          gtag('config', GA4_ID, { anonymize_ip: true });
        } catch (e) { /* localStorage blocked, fail silently */ }
      })();
    </script>
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
    <CookieBanner />

    <script>
      // Reveal-on-scroll: generous rootMargin so all elements render on first load,
      // and newly observed elements reveal as user scrolls.
      function initReveal() {
        const reveals = document.querySelectorAll<HTMLElement>('.reveal, .stagger, .char-reveal');
        if (!('IntersectionObserver' in window)) {
          reveals.forEach((el) => el.classList.add('is-visible'));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                io.unobserve(e.target);
              }
            }
          },
          { threshold: 0, rootMargin: '0px 0px 800% 0px' }
        );
        reveals.forEach((el) => io.observe(el));
      }
      requestAnimationFrame(initReveal);
      // Re-init after page transitions
      document.addEventListener('astro:page-load', () => requestAnimationFrame(initReveal));

      // Mouse-tracked glow on chapter cards
      function initGlow() {
        document.querySelectorAll<HTMLElement>('.chapter-card, .featured-card').forEach((card) => {
          card.addEventListener('mousemove', (ev) => {
            const r = card.getBoundingClientRect();
            card.style.setProperty('--mx', `${ev.clientX - r.left}px`);
            card.style.setProperty('--my', `${ev.clientY - r.top}px`);
          });
        });
      }
      initGlow();
      document.addEventListener('astro:page-load', initGlow);
    </script>
  </body>
</html>
