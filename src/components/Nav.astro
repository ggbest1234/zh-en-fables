---
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);
---

<nav class="nav" transition:persist="nav">
  <div class="container nav-inner">
    <a href="/" class="brand" aria-label="Home">
      <span class="brand-mark">智</span>
      <span class="brand-text">
        <span class="en">Fables</span>
        <span class="zh">寓言</span>
      </span>
    </a>
    <div class="nav-links">
      <a class={`nav-link ${isActive('/') ? 'is-active' : ''}`} href="/">Index</a>
      <a class={`nav-link ${isActive('/chapters') || path.startsWith('/chapter/') ? 'is-active' : ''}`} href="/#chapters">Chapters</a>
      <a class="nav-link cta btn btn-primary btn-sm" href="https://x.com/" target="_blank" rel="noopener">Follow on X →</a>
    </div>
  </div>
</nav>
