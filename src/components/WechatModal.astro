---
// WeChat modal trigger + dialog.
// Opens a glass card overlay showing the QR code, account name, and tagline.
---

<button
  type="button"
  class="wechat-trigger nav-link cta btn btn-primary btn-sm"
  data-wechat-open
  aria-haspopup="dialog"
  aria-controls="wechat-modal"
>
  微信公众号
</button>

<div
  id="wechat-modal"
  class="wechat-modal"
  role="dialog"
  aria-modal="true"
  aria-labelledby="wechat-modal-title"
  hidden
>
  <div class="wechat-backdrop" data-wechat-close></div>
  <div class="wechat-card">
    <button
      type="button"
      class="wechat-close"
      data-wechat-close
      aria-label="Close"
    >×</button>

    <div class="wechat-name">
      <span class="wechat-name-zh">汇知津</span>
      <span class="wechat-name-tagline">词有根，言有源</span>
    </div>

    <div class="wechat-qr-wrap">
      <img
        src="/wechat-qr.jpg"
        alt="汇知津 微信公众号 二维码"
        width="240"
        height="240"
        loading="lazy"
      />
      <div class="wechat-qr-corner wechat-qr-corner-tl"></div>
      <div class="wechat-qr-corner wechat-qr-corner-tr"></div>
      <div class="wechat-qr-corner wechat-qr-corner-bl"></div>
      <div class="wechat-qr-corner wechat-qr-corner-br"></div>
    </div>

    <div class="wechat-hint">
      <span class="wechat-hint-step">①</span>
      <span>Open WeChat and tap <strong>Scan</strong></span>
    </div>
    <div class="wechat-hint">
      <span class="wechat-hint-step">②</span>
      <span>Follow <strong>汇知津</strong></span>
    </div>

    <div class="wechat-divider"><span>or</span></div>

    <a
      class="wechat-x-link"
      href="https://x.com/AZ_fanta"
      target="_blank"
      rel="noopener"
    >
      <svg class="wechat-x-icon" viewBox="0 0 24 24" width="14" height="14" fill="currentColor" aria-hidden="true">
        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
      </svg>
      <span>Follow <strong>@AZ_fanta</strong> on X</span>
    </a>
  </div>
</div>

<style>
  .wechat-trigger {
    /* Inherits .btn .btn-primary .btn-sm from global */
  }

  /* Modal overlay */
  .wechat-modal {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: grid;
    place-items: center;
    padding: var(--s-4);
    animation: wechat-fade 0.2s ease-out;
  }
  .wechat-modal[hidden] { display: none; }

  @keyframes wechat-fade {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  .wechat-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(26, 26, 26, 0.45);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }

  /* Glass card */
  .wechat-card {
    position: relative;
    z-index: 1;
    display: grid;
    justify-items: center;
    gap: var(--s-4);
    width: 100%;
    max-width: 380px;
    padding: var(--s-8) var(--s-6) var(--s-6);
    background: var(--glass-bg-strong);
    border: 1px solid var(--glass-border-strong);
    border-radius: var(--r-lg);
    backdrop-filter: blur(24px) saturate(180%);
    -webkit-backdrop-filter: blur(24px) saturate(180%);
    box-shadow: var(--shadow-lg);
    animation: wechat-pop 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  }
  @keyframes wechat-pop {
    from { opacity: 0; transform: scale(0.92) translateY(8px); }
    to   { opacity: 1; transform: scale(1) translateY(0); }
  }

  .wechat-close {
    position: absolute;
    top: 12px; right: 12px;
    width: 32px; height: 32px;
    display: grid; place-items: center;
    border-radius: var(--r-sm);
    border: none;
    background: transparent;
    color: var(--ink-3);
    font-size: 1.5rem;
    line-height: 1;
    cursor: pointer;
    transition: all 0.15s ease;
  }
  .wechat-close:hover {
    background: var(--glass-bg);
    color: var(--ink);
  }

  /* Account name block */
  .wechat-name {
    display: grid;
    justify-items: center;
    gap: 6px;
    padding-top: var(--s-2);
  }
  .wechat-name-zh {
    font-family: var(--font-zh-display);
    font-size: 2.25rem;
    letter-spacing: 0.08em;
    color: var(--accent-zh);
    line-height: 1;
    text-shadow: 0 0 24px var(--accent-zh-glow);
  }
  .wechat-name-tagline {
    font-family: var(--font-zh-body);
    font-size: 0.95rem;
    color: var(--ink-3);
    letter-spacing: 0.18em;
  }

  /* QR code with corner brackets */
  .wechat-qr-wrap {
    position: relative;
    width: 240px;
    height: 240px;
    padding: 12px;
    background: #fff;
    border-radius: var(--r);
    box-shadow: 0 4px 16px -4px rgba(26, 26, 26, 0.15);
  }
  .wechat-qr-wrap img {
    width: 100%;
    height: 100%;
    display: block;
  }
  .wechat-qr-corner {
    position: absolute;
    width: 16px;
    height: 16px;
    border: 2px solid var(--accent-zh);
  }
  .wechat-qr-corner-tl { top: -2px;    left: -2px;    border-right: none; border-bottom: none; }
  .wechat-qr-corner-tr { top: -2px;    right: -2px;   border-left:  none; border-bottom: none; }
  .wechat-qr-corner-bl { bottom: -2px; left: -2px;    border-right: none; border-top:    none; }
  .wechat-qr-corner-br { bottom: -2px; right: -2px;   border-left:  none; border-top:    none; }

  /* Hints */
  .wechat-hint {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 0.875rem;
    color: var(--ink-2);
  }
  .wechat-hint-step {
    display: inline-grid;
    place-items: center;
    width: 22px; height: 22px;
    border-radius: 50%;
    background: var(--accent-zh);
    color: #fff;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 600;
    flex-shrink: 0;
  }

  /* Divider with 'or' label */
  .wechat-divider {
    display: flex;
    align-items: center;
    width: 100%;
    margin: 4px 0 2px;
    color: var(--ink-4);
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .wechat-divider::before,
  .wechat-divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--glass-border);
  }
  .wechat-divider span {
    padding: 0 12px;
  }

  /* X link inside modal */
  .wechat-x-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    border-radius: var(--r-sm);
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    color: var(--ink-2);
    font-size: 0.875rem;
    text-decoration: none;
    transition: all 0.18s ease;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .wechat-x-link:hover {
    background: var(--glass-bg-strong);
    border-color: var(--ink-4);
    color: var(--ink);
    transform: translateY(-1px);
  }
  .wechat-x-link strong { color: var(--ink); font-weight: 510; }
  .wechat-x-icon {
    flex-shrink: 0;
    opacity: 0.85;
  }
  .wechat-x-link:hover .wechat-x-icon { opacity: 1; }
</style>

<script>
function initWechat() {
  const modal = document.getElementById('wechat-modal');
  if (!modal) return;

  const open = () => {
    modal.hidden = false;
    document.body.style.overflow = 'hidden';
    const close = modal.querySelector<HTMLElement>('.wechat-close');
    close?.focus();
  };
  const close = () => {
    modal.hidden = true;
    document.body.style.overflow = '';
  };

  // Open triggers — bind to ALL [data-wechat-open] elements site-wide.
  // After view-transitions, new page elements (e.g. Footer link) are present
  // but unflagged, so we bind them; already-bound elements are skipped.
  document.querySelectorAll<HTMLElement>('[data-wechat-open]').forEach((btn) => {
    if ((btn as any)._wechatBound) return;
    (btn as any)._wechatBound = true;
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      open();
    });
  });

  // Close triggers (backdrop + close button). Re-bind safely every init.
  modal.querySelectorAll<HTMLElement>('[data-wechat-close]').forEach((el) => {
    if ((el as any)._wechatBound) return;
    (el as any)._wechatBound = true;
    el.addEventListener('click', close);
  });

  // Esc to close (single global listener)
  if (!(document as any)._wechatEscBound) {
    (document as any)._wechatEscBound = true;
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal.hidden) close();
    });
  }
}
initWechat();
document.addEventListener('astro:page-load', initWechat);
</script>
